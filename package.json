{
  "name": "focus-studio",
  "version": "1.0.3",
  "main": "./out/main/index.js",
  "author": "Antigravity",
  "homepage": "./",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.fstudio.erp",
    "productName": "FocusStudio",
    "icon": "assets/icon.ico",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "asarUnpack": [
      "out/**/*"
    ],
    "files": [
      "out/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "adm-zip": "^0.6.0",
    "archiver": "^8.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "lucide-react": "^0.368.0",
    "multer": "^2.1.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^8.0.8"
  }
}